    "gsap": "^3.14.2",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "next-sanity": "^12.1.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sanity": "^5.17.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.1",
    "@tailwindcss/postcss": "^4",
