{
  "name": "zion-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "pages:build": "npx @opennextjs/cloudflare build",
    "start": "next start",
    "lint": "eslint",
    "deploy": "npx @opennextjs/cloudflare build && cp .open-next/worker.js .open-next/assets/_worker.js && cp -r .open-next/cloudflare .open-next/middleware .open-next/server-functions .open-next/.build .open-next/assets/ && npx wrangler pages deploy .open-next/assets --project-name zionsberg"
  },
